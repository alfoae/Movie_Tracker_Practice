<Page x:Class="Movie_Tracker.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Movie_Tracker.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">

    <StackPanel Margin="20">
        <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="{DynamicResource SelectLanguage}" Margin="0,10,0,5"/>
        <ComboBox x:Name="CmbLanguage" Width="200" HorizontalAlignment="Left" SelectionChanged="SettingChanged">
            <ComboBoxItem Content="Українська" Tag="UA"/>
            <ComboBoxItem Content="English" Tag="EN"/>
        </ComboBox>

        <TextBlock Text="{DynamicResource ThemeLabel}" Margin="0,20,0,5" Foreground="Gray"/>
        <ComboBox x:Name="CmbTheme" Width="200" HorizontalAlignment="Left" SelectionChanged="SettingChanged">
            <ComboBoxItem Content="{DynamicResource Light}" Tag="Light"/>
            <ComboBoxItem Content="{DynamicResource Dark}" Tag="Dark"/>
        </ComboBox>
    </StackPanel>

</Page>
