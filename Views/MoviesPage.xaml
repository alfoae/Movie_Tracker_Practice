<Page x:Class="Movie_Tracker.MoviesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Movie_Tracker"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MoviesPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Bottom">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Назва фільму:" FontSize="12" Foreground="Gray"/>
                <TextBox x:Name="TxtTitle" Width="200" Height="28" Padding="3"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Рік:" FontSize="12" Foreground="Gray"/>
                <TextBox x:Name="TxtYear" Width="70" Height="28" Padding="3"/>
            </StackPanel>

            <StackPanel Margin="0,0,15,0">
                <TextBlock Text="Жанр:" FontSize="12" Foreground="Gray"/>
                <TextBox x:Name="TxtGenre" Width="120" Height="28" Padding="3"/>
            </StackPanel>

            <Button Content="Додати фільм" Width="100" Height="28" VerticalAlignment="Bottom" Click="BtnAdd_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5" VerticalAlignment="Top" Panel.ZIndex="1">
            <TextBlock Text="🔍 Пошук:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>
            <TextBox x:Name="TxtSearch" Width="250" Height="28" Padding="3" TextChanged="TxtSearch_TextChanged" ToolTip="Шукати за назвою або жанром"/>
        </StackPanel>
        
        <DataGrid x:Name="MoviesGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" 
                  AlternatingRowBackground="#f9f9f9" Margin="0,0,0,15">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Рік" Binding="{Binding Year}" Width="80"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120"/>
                <DataGridCheckBoxColumn Header="Переглянуто" Binding="{Binding IsWatched}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Зберегти зміни" Width="150" Height="30" Margin="0,0,15,0" Click="BtnSave_Click"/>
            <Button Content="🗑 Видалити вибране" Width="150" Height="30" Foreground="Red" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>
