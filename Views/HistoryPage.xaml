<Page x:Class="Movie_Tracker.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Movie_Tracker.Views"
      Title="HistoryPage"
      Background="{DynamicResource BackgroundColor}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource HistoryTitle}" FontSize="24" FontWeight="Bold" 
                   Foreground="{DynamicResource TextColor}" Margin="0,0,0,20"/>

        <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="{DynamicResource BackgroundColor}"
                  RowBackground="{DynamicResource SurfaceColor}"
                  AlternatingRowBackground="{DynamicResource BackgroundColor}"
                  Foreground="{DynamicResource TextColor}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource Added}" Binding="{Binding AddedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                <DataGridTextColumn Header="{DynamicResource Deleted}" Binding="{Binding DeletedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                <DataGridCheckBoxColumn Header="{DynamicResource Reviewed}" Binding="{Binding IsWatched}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
